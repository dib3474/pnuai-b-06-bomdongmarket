# 이 파일을 .env로 복사한 뒤 placeholder를 로컬 비밀값으로 교체하세요.
# .env는 .gitignore에 등록되어 커밋되지 않습니다.

# Docker Compose 백엔드 설정
# Spring Boot를 직접 실행할 때는 DB_URL의 db:3306을 localhost:3307로 바꾸세요.
DB_URL=jdbc:mysql://db:3306/farmbroker?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=replace-with-local-db-password
JPA_DDL_AUTO=update
JPA_OPEN_IN_VIEW=false
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false
SERVER_CONTEXT_PATH=/api

# JWT 서명 키(최소 32바이트)
JWT_SECRET=replace-with-at-least-32-character-secret

# JWT 만료 시간(ms, 기본 1일)
JWT_EXPIRATION=86400000

# Gemini API 설정
GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
