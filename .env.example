# 이 파일을 복사해 .env 를 만들면 docker-compose 가 자동으로 읽습니다.
#   cp .env.example .env
# .env 는 .gitignore 에 등록되어 있어 커밋되지 않습니다.

# MySQL root 비밀번호 (컨테이너 DB용 — 최초 볼륨 생성 시 적용됨)
DB_PASSWORD=farmbroker1234

# JWT 서명 키 (HS256 — 최소 32바이트)
JWT_SECRET=12341234123412341234123412341234

# JWT 만료 시간 (ms) — 기본 1일
JWT_EXPIRATION=86400000
